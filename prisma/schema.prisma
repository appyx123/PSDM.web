// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Member {
  id                    String             @id @default(cuid())
  name                  String
  prn                   String             @unique
  department            String
  position              String             @default("Staff")
  basePoints            Int                @default(100)
  status                String             @default("active")
  joinDate              String
  
  // EWS Treatment Info
  treatmentActive       Boolean            @default(false)
  treatmentLevel        String?            // "SP1", "SP2"
  treatmentPhase        String?            // "REDEMPTION", "FALLBACK_ATTENDANCE"
  treatmentStartDate    String?
  treatmentStartPoints  Int?
  treatmentTargetPoints Int?
  treatmentDurationDays Int?

  attendances           AttendanceRecord[]
  pointLogs             PointLog[]
  spLogs                SPLog[]
  user                  User?
}

model SPLog {
  id        String   @id @default(cuid())
  memberId  String
  level     String   // SP1, SP2, SP3
  reason    String
  notes     String?
  issuedAt  DateTime @default(now())
  member    Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
}

model User {
  id        String   @id @default(cuid())
  role      String   // "ADMIN" or "PENGURUS"
  email     String?  @unique
  prn       String?  @unique
  name      String
  password  String
  createdAt DateTime @default(now())

  // Profile fields
  fullName           String?
  gender             String?
  originCity         String?
  originCityOther    String?
  domicileCity       String?
  domicileCityOther  String?
  angkatan           String?
  nim                String?
  faculty            String?
  majorProgram       String?
  phoneNumber        String?
  instagram          String?
  image              String?

  memberId  String?  @unique
  member    Member?  @relation(fields: [memberId], references: [id], onDelete: SetNull)
  
  audits    SettingsAudit[]
}

model SystemSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String
}

model SettingsAudit {
  id        String   @id @default(cuid())
  adminId   String
  admin     User     @relation(fields: [adminId], references: [id])
  key       String
  oldValue  String?
  newValue  String
  changedAt DateTime @default(now())
}

model PointLog {
  id          String   @id @default(cuid())
  memberId    String
  type        String   // "REWARD" or "PUNISHMENT"
  category    String   // e.g., "Pelanggaran Atribut", "Mentor Internal"
  points      Int      // The exact point value (e.g., 15, -6)
  description String   // Admin notes
  createdAt   DateTime @default(now())
  
  member      Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
}

model Activity {
  id          String             @id @default(cuid())
  name        String
  date        String
  description String
  scope       String
  attendees   AttendanceRecord[]
}

model AttendanceRecord {
  id         String   @id @default(cuid())
  memberId   String
  activityId String
  status     String
  isEmergencyIzin Boolean @default(false)
  emergencyReason String?
  
  member     Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  activity   Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@unique([memberId, activityId])
}

model PointCategory {
  id        String   @id @default(cuid())
  name      String
  type      String   // "REWARD" or "PUNISHMENT"
  points    Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
